# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Database (SQLite for MVP, swap for PostgreSQL in prod)
DATABASE_URL=sqlite+aiosqlite:///./industrial_copilot.db

# Storage paths
CHROMA_PERSIST_DIR=../storage/chromadb
UPLOAD_DIR=../storage/uploads

# Embedding model (BAAI/bge-small-en-v1.5 or all-MiniLM-L6-v2)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FALLBACK_EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
LLM_TEMPERATURE=0.1
MAX_RETRIEVAL_CHUNKS=5

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_ENV=development
SECRET_KEY=change_me_in_production_to_a_long_random_string
